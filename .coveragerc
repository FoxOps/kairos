# Configuration pour pytest-cov

[run]
# Source packages à mesurer
source = app

omit =
    */tests/*
    */test_*
    */conftest.py
    */__pycache__/*
    */venv/*
    */.venv/*

# Exclure les tests et les fichiers temporaires

[report]
# Exclure les lignes de code non critiques
exclude_lines =
    pragma: no cover
    def __repr__
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @abstractmethod

[html]
directory = htmlcov
