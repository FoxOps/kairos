# =============================================================================
# Leviia Schedule - Configuration par Variables d'Environnement
# =============================================================================
#
# Ce fichier contient toutes les variables d'environnement disponibles pour
# configurer Leviia Schedule.
#
# INSTRUCTIONS:
# 1. Copiez ce fichier en .env : cp .env.example .env
# 2. Modifiez les valeurs selon vos besoins
# 3. Le fichier .env sera automatiquement chargé au démarrage (si python-dotenv est installé)
#
# Pour la production, il est recommandé de définir ces variables directement
# dans l'environnement du système plutôt que d'utiliser un fichier .env
#
# =============================================================================

# =============================================================================
# CONFIGURATION DE BASE DE FLASK
# =============================================================================

# Clé secrète pour Flask (OBLIGATOIRE en production)
# Générez une clé sécurisée avec : python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=ta-cle-secrete-ici

# URI de la base de données
# SQLite reste la base de données par défaut
# Format SQLite : sqlite:///chemin/vers/app.db
# Format PostgreSQL : postgresql://utilisateur:motdepasse@hote:port/base_de_donnees
# Format MariaDB : mariadb://utilisateur:motdepasse@hote:port/base_de_donnees
# Format MySQL : mysql://utilisateur:motdepasse@hote:port/base_de_donnees
# 
# ⚠️  IMPORTANT: En production, SQLite n'est pas recommandé avec plusieurs processus workers.
# Préférez PostgreSQL ou MariaDB pour les environnements de production.
DATABASE_URL=sqlite:///app.db

# Environnement Flask (development, production, testing)
FLASK_ENV=development

# Mode test (true/false)
FLASK_TESTING=false

# =============================================================================
# CONFIGURATION DE LA BASE DE DONNÉES
# =============================================================================

# Désactiver le suivi des modifications SQLAlchemy (recommandé: false)
SQLALCHEMY_TRACK_MODIFICATIONS=false

# Afficher les requêtes SQL dans les logs (pour le débogage)
SQLALCHEMY_ECHO=false

# Options du moteur SQLAlchemy (JSON valide)
# Exemple: {"connect_args": {"timeout": 30}, "pool_pre_ping": true, "pool_recycle": 3600}
# Laissez vide pour utiliser les valeurs par défaut
SQLALCHEMY_ENGINE_OPTIONS=

# =============================================================================
# CONFIGURATION D'AUTHENTIFICATION
# =============================================================================

# Désactiver l'authentification (DANGER: ne jamais activer en production!)
LOGIN_DISABLED=false

# Durée du cookie "se souvenir de moi" en secondes (par défaut: 86400 = 1 jour)
REMEMBER_COOKIE_DURATION=86400

# Protection de session (none, basic, strong)
SESSION_PROTECTION=strong

# =============================================================================
# CONFIGURATION OIDC/SSO (Optionnelle)
# =============================================================================

# Activer l'authentification OIDC/SSO (true/false)
OIDC_ENABLED=false

# URL du fournisseur OIDC (ex: Keycloak, Okta, etc.)
# Exemple pour Keycloak: https://keycloak.example.com/realms/myrealm
OIDC_ISSUER=

# Client ID pour l'application OIDC
OIDC_CLIENT_ID=

# Client Secret pour l'application OIDC
OIDC_CLIENT_SECRET=

# URL de redirection après l'authentification OIDC
# Doit correspondre à l'URL configurée dans le fournisseur OIDC
# Exemple: http://localhost:5000/oidc/callback
OIDC_REDIRECT_URI=

# URL vers laquelle le fournisseur OIDC redirige après une déconnexion
# (RP-initiated logout). Doit être enregistrée côté fournisseur
# (ex: PostLogoutRedirectUris). Sans ça, /logout ne termine que la
# session locale : la session côté fournisseur reste active et la
# prochaine connexion ré-authentifie silencieusement via SSO.
# Exemple: http://localhost:5000
OIDC_POST_LOGOUT_REDIRECT_URI=

# Nom du claim pour l'email dans le token OIDC (par défaut: email)
OIDC_EMAIL_CLAIM=email

# Nom du claim pour le nom dans le token OIDC (par défaut: name)
OIDC_NAME_CLAIM=name

# Nom du claim pour le nom d'utilisateur dans le token OIDC (par défaut: preferred_username)
OIDC_USERNAME_CLAIM=preferred_username

# Nom du claim pour les groupes dans le token OIDC (optionnel)
# Si défini, les groupes seront synchronisés avec les groupes locaux
OIDC_GROUPS_CLAIM=

# Nom du claim pour les rôles dans le token OIDC (optionnel)
# Si défini, les rôles seront synchronisés avec les rôles locaux
OIDC_ROLES_CLAIM=

# Algorithme de signature du token OIDC (par défaut: RS256)
OIDC_SIGNATURE_ALGORITHMS=RS256

# Scope OIDC (par défaut: openid profile email)
OIDC_SCOPE=openid profile email

# Si vrai, l'authentification basique est désactivée lorsque OIDC est activé (true/false)
OIDC_DISABLE_BASIC_AUTH=true


# =============================================================================
# CONFIGURATION DES ERREURS
# =============================================================================

# Afficher les détails des erreurs en mode développement
# WARNING: NE JAMAIS activer en production !
DEBUG_ERRORS=false

# Afficher les pages d'erreur personnalisées
SHOW_CUSTOM_ERROR_PAGES=true

# Message pour les erreurs 500 (Erreur interne du serveur)
ERROR_500_MESSAGE=Une erreur interne du serveur s'est produite. Veuillez reessayer plus tard.

# Message pour les erreurs 503 (Service indisponible)
ERROR_503_MESSAGE=Service temporairement indisponible. Veuillez reessayer dans quelques instants.

# Délai de réessai pour les erreurs 503 (en secondes)
ERROR_503_RETRY_AFTER=300

# =============================================================================
# CONFIGURATION DU LOGGING
# =============================================================================

# Niveau de log principal (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Dossier des logs (relatif au répertoire du projet ou chemin absolu)
LOG_DIR=logs

# Taille maximale des fichiers de log en octets (par défaut: 5 Mo = 5242880)
LOG_FILE_SIZE=5242880

# Nombre de fichiers de backup à conserver
LOG_BACKUP_COUNT=10

# Noms des fichiers de log
LOG_FILE_APP=leviia-app.log
LOG_FILE_ERRORS=leviia-errors.log
LOG_FILE_HTTP=leviia-http-errors.log
LOG_FILE_DEBUG=leviia-debug.log
LOG_FILE_AUDIT=leviia-audit.log

# Niveaux de log par module (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL_APP=
LOG_LEVEL_ERRORS=ERROR
LOG_LEVEL_HTTP=WARNING
LOG_LEVEL_DEBUG=DEBUG
LOG_LEVEL_AUDIT=INFO

# Format des logs
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_DATE_FORMAT=%Y-%m-%d %H:%M:%S

# Activer le syslog pour la production
SYSLOG_ENABLED=false

# Adresse du syslog (par défaut: /dev/log pour Unix, localhost:514 pour réseau)
SYSLOG_ADDRESS=/dev/log

# Facility syslog (local0, local1, ..., local7, user, daemon, etc.)
SYSLOG_FACILITY=local0

# Filtrer les données sensibles dans les logs (recommandé: true)
LOG_FILTER_SENSITIVE=true

# Patterns supplémentaires pour le filtrage des données sensibles (séparés par des virgules)
# Exemple: "password,secret,token,api_key"
LOG_FILTER_PATTERNS=

# =============================================================================
# CONFIGURATION DE SECURITE
# =============================================================================

# Desactiver le cache pour les pages d'erreur (recommandé: 0)
SEND_FILE_MAX_AGE_DEFAULT=0

# Activer CORS (Cross-Origin Resource Sharing)
CORS_ENABLED=false

# =============================================================================
# CONFIGURATION DES DONNEES PAR DEFAUT
# =============================================================================

# Email de l'utilisateur admin par défaut
DEFAULT_ADMIN_EMAIL=admin@leviia.local

# Mot de passe de l'utilisateur admin par défaut
# WARNING: Changez cette valeur après la première connexion !
DEFAULT_ADMIN_PASSWORD=admin123

# Nom du groupe par défaut
DEFAULT_GROUP_NAME=Defaut

# Le groupe par défaut fait partie du planning (true/false)
DEFAULT_GROUP_IN_SCHEDULE=true

# Le groupe par défaut fait partie des astreintes (true/false)
DEFAULT_GROUP_IN_ONCALL=true

# =============================================================================
# CONFIGURATION DES TYPES DE SHIFTS PAR DEFAUT
# =============================================================================

# Types de shifts par défaut au format JSON
# Format: [{"name": "nom", "label": "libelle", "start_hour": heure_debut, "end_hour": heure_fin}, ...]
# Laissez vide pour utiliser les valeurs par défaut du code
DEFAULT_SHIFT_TYPES=

# =============================================================================
# CONFIGURATION DE L'EXPORT ICS
# =============================================================================

# Durée de validité du token ICS en jours (par défaut: 365)
ICS_TOKEN_EXPIRY_DAYS=365

# =============================================================================
# CONFIGURATION DES NOTIFICATIONS PAR EMAIL
# =============================================================================
#
# Rappels hebdomadaires par email (shifts + astreintes), envoyés par les
# scripts scripts/send_shift_notifications.py et
# scripts/send_oncall_notifications.py - à déclencher via cron, pas par
# l'application Flask elle-même (voir scripts/cron_example.sh).
# Un seul email par semaine et par utilisateur (NotificationLog empêche
# les doublons si un script est relancé).

# Activer l'envoi des notifications par email (true/false)
# Si false (ou si NOTIFICATION_FROM_EMAIL/SMTP_HOST manquent), les
# scripts ne font rien et se terminent silencieusement (code 0).
NOTIFICATIONS_ENABLED=false

# Adresse email de l'expéditeur
NOTIFICATION_FROM_EMAIL=

# Serveur SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# Délai d'attente de connexion SMTP en secondes
SMTP_TIMEOUT=10

# URL de base de l'application, utilisée pour le lien "Voir le planning"/
# "Voir les astreintes" dans les emails (ex: https://schedule.example.com)
# Laisser vide pour omettre le lien.
NOTIFICATION_APP_BASE_URL=

# =============================================================================
# CONFIGURATION DES PERFORMANCES
# =============================================================================

# Taille du pool de connexions à la base de données
DATABASE_POOL_SIZE=5

# Nombre maximal de connexions supplémentaires
DATABASE_MAX_OVERFLOW=10

# Délai d'attente pour la connexion à la base de données (en secondes)
DATABASE_CONNECT_TIMEOUT=30

# =============================================================================
# EXEMPLES DE CONFIGURATION COMPLETE
# =============================================================================

# Configuration pour la production avec PostgreSQL:
# DATABASE_URL=postgresql://leviia_user:secure_password@localhost:5432/leviia_db
# FLASK_ENV=production
# LOG_LEVEL=WARNING
# SQLALCHEMY_ECHO=false
# DEBUG_ERRORS=false
# SYSLOG_ENABLED=true
# CORS_ENABLED=false

# Configuration pour la production avec MariaDB:
# DATABASE_URL=mariadb://leviia_user:secure_password@localhost:3306/leviia_db
# FLASK_ENV=production
# LOG_LEVEL=WARNING
# SQLALCHEMY_ECHO=false
# DEBUG_ERRORS=false
# SYSLOG_ENABLED=true
# CORS_ENABLED=false

# Configuration pour le développement:
# FLASK_ENV=development
# LOG_LEVEL=DEBUG
# SQLALCHEMY_ECHO=true
# DEBUG_ERRORS=true
# SYSLOG_ENABLED=false

# Configuration pour les tests:
# FLASK_ENV=testing
# FLASK_TESTING=true
# DATABASE_URL=sqlite:///:memory:
# LOG_LEVEL=DEBUG

# =============================================================================
# NOTES IMPORTANTES
# =============================================================================

# 1. En production, NE JAMAIS utiliser SQLite avec plusieurs processus workers.
#    Utilisez PostgreSQL ou MariaDB pour les environnements multi-processus.

# 2. La clé SECRET_KEY doit être longue, aléatoire et gardée secrète.
#    Ne la commitez JAMAIS dans le dépôt Git.

# 3. Pour les environnements Docker, vous pouvez monter le fichier .env
#    ou passer les variables directement via -e.

# 4. Les variables booléennes acceptent: true, True, TRUE, false, False, FALSE, 1, 0

# 5. Les variables numériques doivent être des entiers valides.

# 6. Les chemins de fichiers peuvent être relatifs (au répertoire du projet)
#    ou absolus.

# =============================================================================
