# =============================================================================
# Leviia Schedule - Configuration OIDC pour Docker
# =============================================================================
#
# Ce fichier contient les variables d'environnement spécifiques pour
# configurer l'authentification OIDC avec Docker.
#
# INSTRUCTIONS:
# 1. Copiez ce fichier en .env : cp .env.oidc.example .env
# 2. Modifiez les valeurs selon vos besoins
# 3. Utilisez avec: docker-compose --env-file .env up -d
#
# =============================================================================

# =============================================================================
# CONFIGURATION OIDC/SSO (OBLIGATOIRE pour l'authentification OIDC)
# =============================================================================

# Activer l'authentification OIDC/SSO
OIDC_ENABLED=true

# Nom du fournisseur OIDC (pour les logs et l'interface)
OIDC_PROVIDER_NAME=oidc-mock

# URL du fournisseur OIDC - DOIT utiliser le nom du service Docker
# En développement avec docker-compose, utilisez le nom du service (ex: oidc-mock)
# et le port interne du conteneur (8080 pour oidc-server-mock)
OIDC_ISSUER=http://oidc-mock:8080

# Client ID pour l'application OIDC - DOIT correspondre à la configuration du fournisseur
OIDC_CLIENT_ID=leviia-app

# Client Secret pour l'application OIDC - DOIT correspondre à la configuration du fournisseur
OIDC_CLIENT_SECRET=leviia-secret

# URL de redirection après l'authentification OIDC
# DOIT correspondre exactement à l'URL configurée dans le fournisseur OIDC
OIDC_REDIRECT_URI=http://localhost:5000/oidc/callback

# Scope OIDC (par défaut: openid profile email)
OIDC_SCOPE=openid profile email

# Si vrai, l'authentification basique (email/mot de passe) est désactivée lorsque OIDC est activé
OIDC_DISABLE_BASIC_AUTH=true

# =============================================================================
# CONFIGURATION DE BASE DE FLASK
# =============================================================================

# Clé secrète pour Flask (OBLIGATOIRE)
# Générez une clé sécurisée avec : python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=ta-cle-secrete-ici

# URI de la base de données
DATABASE_URL=sqlite:///app.db

# Environnement Flask
FLASK_ENV=production

# =============================================================================
# CONFIGURATION DES DONNEES PAR DEFAUT
# =============================================================================

# Email de l'utilisateur admin par défaut
DEFAULT_ADMIN_EMAIL=admin@leviia.local

# Mot de passe de l'utilisateur admin par défaut
# WARNING: Changez cette valeur après la première connexion !
DEFAULT_ADMIN_PASSWORD=admin123

# =============================================================================
# NOTES IMPORTANTES POUR DOCKER
# =============================================================================
#
# 1. OIDC_ISSUER doit utiliser le nom du service Docker (ex: oidc-mock) et non localhost
#    car les conteneurs communiquent entre eux via le réseau Docker.
#
# 2. Le port dans OIDC_ISSUER doit être le port INTERNE du conteneur oidc-mock (8080)
#    et non le port mappé sur l'hôte (4011).
#
# 3. OIDC_REDIRECT_URI doit utiliser localhost:5000 car c'est l'URL accessible
#    depuis votre navigateur.
#
# 4. Assurez-vous que le service oidc-mock est démarré AVANT leviia-schedule
#    en utilisant depends_on avec healthcheck dans docker-compose.yml
#
# 5. Pour tester manuellement:
#    - Accédez à http://localhost:5000
#    - Vous devriez être redirigé vers oidc-mock pour la connexion
#    - Utilisez les identifiants configurés dans USERS_CONFIGURATION_INLINE
#
# =============================================================================
