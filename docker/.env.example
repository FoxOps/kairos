# =============================================================================
# Kairos - Configuration par Variables d'Environnement (Docker)
# =============================================================================
#
# Ce fichier est pour un déploiement Docker/Docker Compose - les chemins
# par défaut (base de données, sauvegardes) pointent vers /app/data,
# déjà monté en volume par docker/docker-compose.yml et
# docker/docker-compose.example.yml (survit aux recréations du
# conteneur). Pour un lancement HORS Docker (python run.py direct sur
# la machine), utilisez plutôt le .env.example à la racine du dépôt.
#
# Chaque variable ci-dessous est vérifiée contre le code qui la lit
# réellement (app/config/base.py, run.py, config_oidc.py,
# app/utils/logging/logger.py, scripts/notification_config.py,
# scripts/backup_config.py) - voir aussi
# Docs/reference/ENVIRONMENT_VARIABLES.md pour le détail complet.
#
# INSTRUCTIONS:
# 1. Copiez ce fichier en .env : cp docker/.env.example docker/.env
#    (docker/setup-env.sh le fait automatiquement)
# 2. Modifiez les valeurs selon vos besoins
# 3. docker-compose.yml/docker-compose.example.yml chargent ce fichier
#    via env_file - inutile de le monter manuellement dans le conteneur
#
# =============================================================================

# =============================================================================
# CONFIGURATION DOCKER (image du registry)
# =============================================================================

# Lue uniquement par docker-compose.yml/docker-compose.example.yml
# (substitution de variable), pas par l'application elle-même - image à
# tirer du GitHub Container Registry (ghcr.io). Laissez commentée pour
# un build local avec docker/docker-compose.yml (retombe sur son propre
# défaut kairos:dev tant que la variable est absente, pas juste vide) -
# décommentez uniquement si vous utilisez docker-compose.example.yml
# (image du registry, pas de build local). Voir Docs/deployment/docker.md.
# KAIROS_IMAGE=ghcr.io/foxops/kairos:latest

# =============================================================================
# CONFIGURATION DE BASE DE FLASK
# =============================================================================

# Clé secrète pour Flask (OBLIGATOIRE en production)
# Générez une clé sécurisée avec : python -c "import secrets; print(secrets.token_hex(32))"
# Sans valeur fixe, une nouvelle clé aléatoire est générée à chaque
# redémarrage : toutes les sessions existantes sont alors invalidées.
SECRET_KEY=ta-cle-secrete-ici

# Environnement Flask - sélectionne uniquement gunicorn (production) ou
# le serveur de développement Flask (toute autre valeur), voir
# docker/entrypoint.sh. N'active pas un profil de configuration
# séparé : chaque réglage de ce fichier reste contrôlé par sa propre
# variable, quelle que soit la valeur de FLASK_ENV.
FLASK_ENV=production

# Mode debug Flask - N'ACTIVEZ JAMAIS EN PRODUCTION : expose le débogueur
# Werkzeug interactif, une vraie surface d'exécution de code à distance
# sur toute exception non gérée. Sans effet quand FLASK_ENV=production
# (gunicorn ne lit pas ce réglage).
FLASK_DEBUG=false

# Mode test Flask (indicateur TESTING natif de Flask)
FLASK_TESTING=false

# URL publique de l'app quand elle tourne derrière un reverse proxy
# (ex: https://schedule.example.com). Optionnel - sert de repli pour les
# liens absolus (export ICS) quand le proxy ne transmet pas correctement
# X-Forwarded-Host à ProxyFix, ce qui exposerait sinon l'IP/le nom interne
# du backend au lieu du bon domaine. Laisser vide pour utiliser request.host_url.
# Peut aussi être configuré dynamiquement (sans redéploiement) via
# /admin/settings une fois l'application démarrée - cette variable reste
# le repli tant qu'aucune valeur n'a été enregistrée depuis l'interface
# d'administration.
PUBLIC_BASE_URL=

# Version affichée par /version et le pied de page - purement
# informatif, aucun effet sur le comportement de l'app.
APP_VERSION=1.0.0-rc2

# =============================================================================
# CONFIGURATION DE LA BASE DE DONNÉES
# =============================================================================

# URI de la base de données.
# Chemin absolu sous /app/data (volume monté) pour que la base survive
# aux recréations du conteneur - un chemin relatif comme sqlite:///app.db
# serait perdu à chaque recréation.
# Format SQLite : sqlite:////chemin/absolu/vers/app.db (4 slashes)
# Format PostgreSQL : postgresql://utilisateur:motdepasse@hote:port/base_de_donnees
# Format MariaDB : mariadb://utilisateur:motdepasse@hote:port/base_de_donnees
# Format MySQL : mysql://utilisateur:motdepasse@hote:port/base_de_donnees
#
# ⚠️  IMPORTANT: En production, SQLite n'est pas recommandé avec plusieurs processus workers.
# Préférez PostgreSQL ou MariaDB pour les environnements de production.
DATABASE_URL=sqlite:////app/data/app.db

# Désactiver le suivi des modifications SQLAlchemy (recommandé: false)
SQLALCHEMY_TRACK_MODIFICATIONS=false

# Options du moteur SQLAlchemy, au format JSON - utile notamment pour
# pool_pre_ping/pool_recycle contre un serveur MySQL/PostgreSQL externe
# (évite une erreur de connexion périmée quand le serveur ferme les
# connexions inactives).
# Exemple: {"pool_pre_ping": true, "pool_recycle": 3600}
# Laissez vide pour utiliser les valeurs par défaut (aucune option).
SQLALCHEMY_ENGINE_OPTIONS=

# =============================================================================
# LIMITATION DE DEBIT (RATE LIMITING)
# =============================================================================

# Activer Flask-Limiter
RATE_LIMIT_ENABLED=true

# Limites par défaut, format Flask-Limiter
RATE_LIMIT_DEFAULT=200 per day, 50 per hour

# =============================================================================
# SECURITE HTTP (COOKIES DE SESSION, TALISMAN)
# =============================================================================

# Cookie de session envoyé uniquement en HTTPS - à activer si un reverse
# proxy TLS (Traefik, nginx, etc.) est placé devant le conteneur
SESSION_COOKIE_SECURE=false

# Bloque l'accès JavaScript au cookie de session
SESSION_COOKIE_HTTPONLY=true

# Politique SameSite du cookie (Lax, Strict, None)
SESSION_COOKIE_SAMESITE=Lax

# Durée de vie de la session en jours
PERMANENT_SESSION_LIFETIME_DAYS=30

# Clé utilisée pour saler certains jetons de sécurité. Générez-la comme
# SECRET_KEY : python -c "import secrets; print(secrets.token_hex(16))"
SECURITY_PASSWORD_SALT=

# Force la redirection HTTPS (Flask-Talisman). Par défaut false ici : le
# cas de départ typique est un docker-compose exposant directement le
# port 5000 sans reverse proxy TLS devant (sinon chaque requête boucle
# sur une redirection https:// que rien ne sert). Passez à true si un
# reverse proxy TLS est bien placé devant le conteneur.
TALISMAN_FORCE_HTTPS=false

# Envoie l'en-tête Strict-Transport-Security
TALISMAN_STRICT_TRANSPORT_SECURITY=false

# =============================================================================
# CONFIGURATION D'AUTHENTIFICATION
# =============================================================================

# Désactiver l'authentification (DANGER: ne jamais activer en production!)
LOGIN_DISABLED=false

# Durée du cookie "se souvenir de moi" en secondes (par défaut: 86400 = 1 jour)
REMEMBER_COOKIE_DURATION=86400

# Protection de session Flask-Login (none, basic, strong)
SESSION_PROTECTION=strong

# =============================================================================
# CONFIGURATION OIDC/SSO (Optionnelle)
# =============================================================================

# Activer l'authentification OIDC/SSO (true/false)
OIDC_ENABLED=false

# URL du fournisseur OIDC (ex: Keycloak, Okta, etc.)
# Exemple pour Keycloak: https://keycloak.example.com/realms/myrealm
OIDC_ISSUER=

# Client ID pour l'application OIDC
OIDC_CLIENT_ID=

# Client Secret pour l'application OIDC
OIDC_CLIENT_SECRET=

# URL de redirection après l'authentification OIDC
# Doit correspondre à l'URL configurée dans le fournisseur OIDC
# Exemple: http://localhost:5000/oidc/callback
OIDC_REDIRECT_URI=

# URL vers laquelle le fournisseur OIDC redirige après une déconnexion
# (RP-initiated logout). Doit être enregistrée côté fournisseur
# (ex: PostLogoutRedirectUris). Sans ça, /logout ne termine que la
# session locale : la session côté fournisseur reste active et la
# prochaine connexion ré-authentifie silencieusement via SSO.
# Exemple: http://localhost:5000
OIDC_POST_LOGOUT_REDIRECT_URI=

# URL du fournisseur OIDC joignable depuis le conteneur, si différente
# de OIDC_ISSUER (IdP sur le même réseau Docker, ex: le service
# oidc-mock de docker/docker-compose.yml).
OIDC_INTERNAL_ISSUER=

# Nom du claim pour l'email dans le token OIDC (par défaut: email)
OIDC_EMAIL_CLAIM=email

# Nom du claim pour le nom dans le token OIDC (par défaut: name)
OIDC_NAME_CLAIM=name

# Nom du claim pour le nom d'utilisateur dans le token OIDC (par défaut: preferred_username)
OIDC_USERNAME_CLAIM=preferred_username

# Nom du claim pour les groupes dans le token OIDC (optionnel)
# Si défini, les groupes seront synchronisés avec les groupes locaux
OIDC_GROUPS_CLAIM=

# Nom du claim pour les rôles dans le token OIDC (optionnel)
# Si défini, les rôles seront synchronisés avec les rôles locaux
OIDC_ROLES_CLAIM=

# Algorithme de signature du token OIDC (par défaut: RS256)
OIDC_SIGNATURE_ALGORITHMS=RS256

# Scope OIDC (par défaut: openid profile email)
OIDC_SCOPE=openid profile email

# Si vrai, l'authentification basique est désactivée lorsque OIDC est activé (true/false)
OIDC_DISABLE_BASIC_AUTH=true

# =============================================================================
# CONFIGURATION DU LOGGING
# =============================================================================

# Niveau de log principal (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Format des lignes de log (format Python logging)
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Fichier de log optionnel supplémentaire, en plus des fichiers
# app.log/error.log/debug.log/http_errors.log/audit.log toujours créés
# sous /app/logs (déjà monté en volume par docker-compose.yml). Laisser
# vide pour ne pas en créer.
LOG_FILE=

# Taille maximale de chaque fichier de log avant rotation, en octets
# (par défaut: 10 Mo = 10485760)
LOG_MAX_BYTES=10485760

# Nombre de fichiers de sauvegarde conservés après rotation
LOG_BACKUP_COUNT=5

# Le filtrage des données sensibles (password=/token=/api_key=) est
# toujours actif et ne peut pas être désactivé - aucune variable
# d'environnement ne le contrôle.

# =============================================================================
# PAGINATION
# =============================================================================

# Taille de page par défaut / maximale pour les listes paginées. Repli
# utilisé uniquement en l'absence de réglage enregistré via
# /admin/settings.
ITEMS_PER_PAGE=20
MAX_PER_PAGE=100

# =============================================================================
# CONFIGURATION DES DONNEES PAR DEFAUT
# =============================================================================
# Lues une seule fois, à la création de la base de données
# (run.py::create_default_data).

# Email de l'utilisateur admin par défaut
DEFAULT_ADMIN_EMAIL=admin@kairos.local

# Mot de passe de l'utilisateur admin par défaut
# WARNING: Changez cette valeur après la première connexion !
DEFAULT_ADMIN_PASSWORD=admin123

# Nom du groupe par défaut
DEFAULT_GROUP_NAME=Defaut

# Le groupe par défaut fait partie du planning (true/false)
DEFAULT_GROUP_IN_SCHEDULE=true

# Le groupe par défaut fait partie des astreintes (true/false)
DEFAULT_GROUP_IN_ONCALL=true

# Les types de shifts par défaut (07h-15h/09h-17h/13h-21h) sont une
# liste fixe dans run.py, non configurable par variable d'environnement
# - à modifier après le premier lancement depuis /admin/shift-types.

# =============================================================================
# CONFIGURATION DE L'EXPORT ICS
# =============================================================================

# Durée de validité du jeton d'abonnement ICS en jours - appliquée
# (User.is_ics_token_expired(), vérifiée par ExportService.resolve_user()
# à chaque accès anonyme par jeton). Peut aussi être configurée
# dynamiquement via /admin/settings - repli tant qu'aucune valeur n'a
# été enregistrée depuis l'interface d'administration.
ICS_TOKEN_EXPIRY_DAYS=365

# =============================================================================
# MONITORING
# =============================================================================

# Active le blueprint app/utils/prometheus_metrics.py (endpoint /metrics
# au format Prometheus). /health et /ready restent toujours actifs
# (sondes Kubernetes), indépendamment de ce réglage.
PROMETHEUS_ENABLED=false

# =============================================================================
# CONFIGURATION DES NOTIFICATIONS PAR EMAIL
# =============================================================================
#
# Rappels hebdomadaires par email (shifts + astreintes). En Docker, ces
# scripts tournent via crond dans le conteneur (docker/entrypoint.sh
# démarre crond si NOTIFICATIONS_ENABLED et/ou BACKUP_ENABLED est actif,
# voir docker/crontabs/appuser). Un seul email par semaine et par
# utilisateur (NotificationLog empêche les doublons si un script est
# relancé).

# Activer l'envoi des notifications par email (true/false)
# Si false (ou si NOTIFICATION_FROM_EMAIL/SMTP_HOST manquent), les
# scripts ne font rien et se terminent silencieusement (code 0).
# Peut aussi être activé/désactivé dynamiquement via /admin/settings -
# repli tant qu'aucune valeur n'a été enregistrée depuis l'interface
# d'administration. SMTP_HOST/NOTIFICATION_FROM_EMAIL restent env-only
# (secrets/déploiement, non migrables).
NOTIFICATIONS_ENABLED=false

# Adresse email de l'expéditeur
NOTIFICATION_FROM_EMAIL=

# Serveur SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# Délai d'attente de connexion SMTP en secondes
SMTP_TIMEOUT=10

# URL de base de l'application, utilisée pour le lien "Voir le planning"/
# "Voir les astreintes" dans les emails (ex: https://schedule.example.com)
# Laisser vide pour omettre le lien.
NOTIFICATION_APP_BASE_URL=

# =============================================================================
# CONFIGURATION DES SAUVEGARDES
# =============================================================================
#
# Sauvegarde de la base de données (locale et/ou S3/S3-compatible). En
# Docker, tourne via crond dans le conteneur (voir ci-dessus) ou depuis
# l'interface d'administration (/admin/backups). Voir
# Docs/deployment/BACKUP_GUIDE.md pour le détail.

# Activer les sauvegardes (true/false). Si false, le script et les
# routes d'administration refusent de créer de nouvelles sauvegardes
# (les sauvegardes déjà existantes restent consultables/téléchargeables).
BACKUP_ENABLED=false

# Sauvegarde locale (fichier compressé dans BACKUP_LOCAL_DIR). Chemin
# absolu sous /app/data (volume monté) pour que les sauvegardes
# survivent aux recréations du conteneur.
BACKUP_LOCAL_ENABLED=true
BACKUP_LOCAL_DIR=/app/data/backups

# Sauvegarde S3 ou S3-compatible (MinIO, etc.) - nécessite le paquet
# optionnel boto3 (pip install boto3)
BACKUP_S3_ENABLED=false
BACKUP_S3_BUCKET=
# Laisser vide pour AWS S3 ; renseigner pour un service S3-compatible
# (ex: http://minio.example.com:9000)
BACKUP_S3_ENDPOINT=
BACKUP_S3_REGION=eu-west-1
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
BACKUP_S3_PREFIX=kairos
BACKUP_S3_USE_SSL=true

# Rétention : nombre de jours et nombre maximal de sauvegardes conservées
# (la limite la plus stricte s'applique)
# Peut aussi être configuré dynamiquement via /admin/settings, mais
# uniquement pour les actions déclenchées depuis l'UI admin - la tâche
# planifiée (cron) continue d'utiliser ces variables d'environnement
# dans tous les cas. Ces variables restent le repli tant qu'aucune
# valeur n'a été enregistrée depuis l'interface d'administration.
BACKUP_RETENTION_DAYS=30
BACKUP_MAX_BACKUPS=30

# Compresser les sauvegardes locales (gzip)
BACKUP_COMPRESS=true

# Inclure un horodatage dans le nom du fichier de sauvegarde, et son
# format (strftime)
BACKUP_INCLUDE_TIMESTAMP=true
BACKUP_TIMESTAMP_FORMAT=%Y%m%d_%H%M%S

# Préfixe du nom de fichier de sauvegarde
BACKUP_PREFIX=kairos_backup

# Vérifier l'intégrité de chaque sauvegarde après création (signature
# SQLite + hash SHA256)
BACKUP_VERIFY=true

# Envoyer un email en cas de succès/échec de sauvegarde - réutilise la
# configuration SMTP des notifications ci-dessus (donc aussi soumis à
# NOTIFICATIONS_ENABLED)
BACKUP_NOTIFY_ON_SUCCESS=false
BACKUP_NOTIFY_ON_FAILURE=true
BACKUP_NOTIFICATION_EMAIL=

# Niveau de log et fichier de log dédiés au script de sauvegarde
# (indépendants de LOG_LEVEL/LOG_FILE ci-dessus - scripts/backup_database.py
# n'importe jamais app/, voir Docs/deployment/BACKUP_GUIDE.md)
BACKUP_LOG_LEVEL=INFO
BACKUP_LOG_FILE=

# =============================================================================
# EXEMPLES DE CONFIGURATION COMPLETE
# =============================================================================

# Configuration pour la production avec PostgreSQL:
# DATABASE_URL=postgresql://kairos_user:secure_password@db:5432/kairos_db
# FLASK_ENV=production
# LOG_LEVEL=WARNING

# Configuration pour la production avec MariaDB:
# DATABASE_URL=mariadb://kairos_user:secure_password@db:3306/kairos_db
# FLASK_ENV=production
# LOG_LEVEL=WARNING

# Configuration pour le développement local (docker/docker-compose.yml):
# FLASK_ENV=development
# FLASK_DEBUG=true
# LOG_LEVEL=DEBUG

# =============================================================================
# NOTES IMPORTANTES
# =============================================================================

# 1. En production, NE JAMAIS utiliser SQLite avec plusieurs processus workers.
#    Utilisez PostgreSQL ou MariaDB pour les environnements multi-processus
#    (docker/entrypoint.sh démarre gunicorn avec 1 seul worker par défaut,
#    justement à cause de cette limitation de SQLite - voir docker/Dockerfile).

# 2. La clé SECRET_KEY doit être longue, aléatoire et gardée secrète.
#    Ne la commitez JAMAIS dans le dépôt Git.

# 3. Pour un lancement HORS Docker, utilisez le .env.example à la racine
#    du dépôt à la place de ce fichier.

# 4. Les variables booléennes acceptent: true, True, TRUE, 1, yes, y, on
#    (et leurs équivalents false: false, False, FALSE, 0, no, n, off)

# 5. Les variables numériques doivent être des entiers valides.

# 6. Les chemins de fichiers peuvent être relatifs (à /app, WORKDIR du
#    conteneur) ou absolus - préférez toujours un chemin absolu sous
#    /app/data pour tout ce qui doit survivre à une recréation du
#    conteneur.
